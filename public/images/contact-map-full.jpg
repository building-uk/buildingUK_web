<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 400" preserveAspectRatio="xMidYMid slice">
  <defs>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#e0e0e0" stroke-width="1"/>
    </pattern>
  </defs>
  
  <!-- Map Background -->
  <rect width="1280" height="400" fill="#f3f4f6"/>
  <rect width="1280" height="400" fill="url(#grid)"/>
  
  <!-- Roads -->
  <path d="M0 200 C300 200, 400 150, 640 200 S900 250, 1280 200" fill="none" stroke="#ddd" stroke-width="20"/>
  <path d="M640 0 L640 400" fill="none" stroke="#fff" stroke-width="15"/>
  <path d="M200 0 L1080 400" fill="none" stroke="#fff" stroke-width="12"/>
  
  <!-- Pin location -->
  <g transform="translate(640, 200)">
    <circle cx="0" cy="0" r="12" fill="#d1b06b" opacity="0.2"/>
    <circle cx="0" cy="0" r="6" fill="#d1b06b"/>
    <path d="M0 0 L-10 -25 L10 -25 Z" fill="#333"/>
    <rect x="-10" y="-35" width="20" height="10" fill="#333"/>
    <text x="0" y="-27" text-anchor="middle" fill="white" font-family="sans-serif" font-size="8" font-weight="bold">UK</text>
  </g>
  
  <!-- Interface Overlay -->
  <rect x="20" y="20" width="140" height="40" rx="4" fill="white" stroke="#ddd"/>
  <text x="40" y="45" font-family="sans-serif" font-size="14" fill="#666">Map Data ©2025</text>
</svg>
